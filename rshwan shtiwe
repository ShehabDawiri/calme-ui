<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Therapist Dashboard - Therapy Session Manager</title>
<style>
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background: #f0f2f5;
    color: #333;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  header {
    background: #4a90e2;
    color: #fff;
    padding: 1rem 1.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
  }
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem;
    max-width: 900px;
    margin: 0 auto 2rem;
  }
  section.upload-area {
    background: white;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);
  }
  .upload-dropzone {
    border: 2px dashed #4a90e2;
    border-radius: 6px;
    padding: 2rem;
    text-align: center;
    color: #555;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  .upload-dropzone.dragover {
    background-color: #e2ecfb;
  }
  .upload-dropzone p {
    margin: 0;
    font-size: 16px;
  }
  .upload-dropzone input[type="file"] {
    display: none;
  }
  .progress-bar-container {
    background: #eee;
    height: 16px;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 0.75rem;
    display: none;
  }
  .progress-bar {
    height: 100%;
    width: 0%;
    background: #4a90e2;
    transition: width 0.3s ease;
  }
  section.dashboard {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .controls {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .controls input[type="text"], .controls select {
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    border-radius: 4px;
    border: 1px solid #ccc;
    flex: 1;
    min-width: 150px;
  }
  .recordings-list {
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);
    max-height: 260px;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .recording-item {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid #eee;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .recording-item:hover {
    background-color: #f5f9ff;
  }
  .recording-item.selected {
    background-color: #d8e7ff;
  }
  .recording-meta {
    font-size: 0.85rem;
    color: #666;
  }
  .transcript-area, .summary-area {
    background: white;
    border-radius: 8px;
    padding: 1rem;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);
    margin-top: 1rem;
  }
  .transcript-title, .summary-title {
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid #ddd;
    padding-bottom: 0.25rem;
  }
  .transcript-content {
    max-height: 180px;
    overflow-y: auto;
    white-space: pre-wrap;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .chart-container {
    width: 100%;
    max-width: 680px;
    height: 220px;
  }
  audio {
    width: 100%;
    margin-top: 0.5rem;
    outline: none;
  }

  /* Responsive */
  @media (max-width: 600px) {
    main {
      padding: 1rem;
      max-width: 100%;
    }
    .controls {
      flex-direction: column;
    }
    .controls input[type="text"], .controls select {
      min-width: 100%;
    }
  }
</style>
</head>
<body>
<header>Therapist Dashboard - Therapy Session Manager</header>
<main>
  <section class="upload-area" aria-label="Upload therapy session recordings">
    <label for="file-upload" class="upload-dropzone" tabindex="0">
      <p>Drag & Drop therapy session files here or click to select files (MP3, WAV, M4A)</p>
      <input id="file-upload" type="file" accept=".mp3,.wav,.m4a" multiple />
    </label>
    <div class="progress-bar-container" aria-hidden="true">
      <div class="progress-bar"></div>
    </div>
  </section>

  <section class="dashboard" aria-label="Therapist sessions dashboard">
    <div class="controls">
      <input type="text" id="search-input" placeholder="Search recordings by patient, date, or keywords" aria-label="Search recordings" autocomplete="off" />
      <select id="filter-type" aria-label="Filter by session type">
        <option value="all">All session types</option>
        <option value="ai-driven">AI-driven</option>
        <option value="live">Live recording</option>
      </select>
    </div>

    <div class="recordings-list" role="list" aria-label="List of therapy session recordings"></div>

    <section class="transcript-area" aria-live="polite" aria-atomic="true" aria-label="Session transcript">
      <div class="transcript-title">Transcript</div>
      <pre class="transcript-content" id="transcript-content">Select a recording to view the transcript.</pre>
      <audio controls id="audio-player" aria-label="Audio player for selected recording" src="" preload="none"></audio>
    </section>

    <section class="summary-area" aria-label="Session summary and analytics">
      <div class="summary-title">Session Summary</div>
      <canvas id="summary-chart" class="chart-container" role="img" aria-label="Session summary chart"></canvas>
      <p id="summary-text" style="margin-top: 1rem; font-size: 0.95rem; color: #444;">Select a recording to view summary details.</p>
    </section>
  </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (() => {
    // Mock recordings data to demo the UI
    const recordings = [
      {
        id: 'rec1',
        patient: 'John Doe',
        date: '2025-03-08',
        duration: '25:32',
        type: 'ai-driven',
        transcript: 'Therapist: How are you feeling today?\nPatient: I have been anxious but coping.',
        summary: {
          anxietyLevel: 7,
          sadnessLevel: 4,
          optimismLevel: 5
        },
        audioUrl: ''
      },
      {
        id: 'rec2',
        patient: 'Jane Smith',
        date: '2025-03-10',
        duration: '30:12',
        type: 'live',
        transcript: 'Therapist: Let\'s talk about your week.\nPatient: It\'s been stressful, but I have taken breaks.',
        summary: {
          anxietyLevel: 5,
          sadnessLevel: 3,
          optimismLevel: 6
        },
        audioUrl: ''
      },
      {
        id: 'rec3',
        patient: 'Mark Johnson',
        date: '2025-03-09',
        duration: '20:45',
        type: 'ai-driven',
        transcript: 'Therapist: How is work going?\nPatient: Feeling overwhelmed but hopeful.',
        summary: {
          anxietyLevel: 6,
          sadnessLevel: 2,
          optimismLevel: 7
        },
        audioUrl: ''
      }
    ];

    // State
    let filteredRecordings = [...recordings];
    let selectedRecordingId = null;

    // DOM Elements
    const recordingsListEl = document.querySelector('.recordings-list');
    const transcriptContentEl = document.getElementById('transcript-content');
    const summaryTextEl = document.getElementById('summary-text');
    const searchInputEl = document.getElementById('search-input');
    const filterTypeEl = document.getElementById('filter-type');
    const audioPlayerEl = document.getElementById('audio-player');
    const uploadDropzone = document.querySelector('.upload-dropzone');
    const fileInput = document.getElementById('file-upload');
    const progressBarContainer = document.querySelector('.progress-bar-container');
    const progressBar = document.querySelector('.progress-bar');

    // Functions
    function renderRecordingList() {
      recordingsListEl.innerHTML = '';
      if (filteredRecordings.length === 0) {
        recordingsListEl.innerHTML = '<p style="padding:1rem; color:#666;">No recordings found.</p>';
        transcriptContentEl.textContent = 'Select a recording to view the transcript.';
        summaryTextEl.textContent = 'Select a recording to view summary details.';
        audioPlayerEl.src = '';
        selectedRecordingId = null;
        updateSelectionHighlight();
        clearChart();
        return;
      }
      filteredRecordings.forEach(rec => {
        const item = document.createElement('div');
        item.setAttribute('role', 'listitem');
        item.tabIndex = 0;
        item.classList.add('recording-item');
        if (rec.id === selectedRecordingId) {
          item.classList.add('selected');
        }
        item.innerHTML = `
          <strong>${rec.patient} - ${rec.date}</strong>
          <div class="recording-meta">Duration: ${rec.duration} | Type: ${rec.type.replace('-', ' ')}</div>
        `;
        item.onclick = () => selectRecording(rec.id);
        item.onkeypress = (e) => { if (e.key === 'Enter') selectRecording(rec.id); };
        recordingsListEl.appendChild(item);
      });
    }

    function selectRecording(id) {
      selectedRecordingId = id;
      const rec = filteredRecordings.find(r => r.id === id);
      if (!rec) return;
      transcriptContentEl.textContent = rec.transcript || 'No transcript available.';
      summaryTextEl.textContent = ''; // will be replaced by chart or other info
      audioPlayerEl.src = rec.audioUrl || '';
      updateSelectionHighlight();
      updateChart(rec.summary);
    }

    function updateSelectionHighlight() {
      document.querySelectorAll('.recording-item').forEach(item => {
        item.classList.remove('selected');
        if (item.textContent.includes(selectedRecordingId)) {
          item.classList.add('selected');
        }
      });
      // Alternative: just rerender list; current simple but effective approach in renderRecordingList
    }

    function filterRecordings() {
      const searchText = searchInputEl.value.trim().toLowerCase();
      const filterType = filterTypeEl.value;

      filteredRecordings = recordings.filter(r => {
        const matchesType = filterType === 'all' || r.type === filterType;
        const matchesText =
          r.patient.toLowerCase().includes(searchText) ||
          r.date.includes(searchText) ||
          (r.transcript && r.transcript.toLowerCase().includes(searchText));
        return matchesType && matchesText;
      });
      // If selected recording is filtered out, reset selection
      if (!filteredRecordings.some(r => r.id === selectedRecordingId)) {
        selectedRecordingId = null;
        clearChart();
      }
      renderRecordingList();
    }

    // Chart rendering with Chart.js
    let chartInstance = null;
    function updateChart(summary) {
      const ctx = document.getElementById('summary-chart').getContext('2d');
      if (chartInstance) {
        chartInstance.destroy();
      }
      if (!summary) {
        clearChart();
        summaryTextEl.textContent = 'No session summary available.';
        return;
      }
      chartInstance = new Chart(ctx, {
        type: 'radar',
        data: {
          labels: ['Anxiety', 'Sadness', 'Optimism'],
          datasets: [{
            label: 'Session Insight Scores',
            data: [summary.anxietyLevel, summary.sadnessLevel, summary.optimismLevel],
            backgroundColor: 'rgba(74, 144, 226, 0.3)',
            borderColor: '#4a90e2',
            borderWidth: 2,
            pointBackgroundColor: '#4a90e2'
          }]
        },
        options: {
          scales: {
            r: {
              angleLines: {
                display: true
              },
              suggestedMin: 0,
              suggestedMax: 10,
              ticks: {
                stepSize: 1,
                color: '#555'
              },
              pointLabels: {
                font: {
                  size: 14
                },
                color: '#333'
              }
            }
          },
          plugins: {
            legend: {
              display: false
            }
          },
          responsive: true,
          maintainAspectRatio: false
        }
      });
    }
    function clearChart() {
      if (chartInstance) {
        chartInstance.destroy();
        chartInstance = null;
      }
      const ctx = document.getElementById('summary-chart').getContext('2d');
      ctx.clearRect(0, 0, ctx.canvas.width, ctx.canvas.height);
    }

    // Upload handlers
    function preventDefaults(e) {
      e.preventDefault();
      e.stopPropagation();
    }
    function highlight() {
      uploadDropzone.classList.add('dragover');
    }
    function unhighlight() {
      uploadDropzone.classList.remove('dragover');
    }
    function handleDrop(e) {
      const dt = e.dataTransfer;
      const files = dt.files;
      handleFiles(files);
    }
    function handleFiles(files) {
      [...files].forEach(file => {
        if (!['audio/mpeg', 'audio/wav', 'audio/mp4', 'audio/x-m4a'].includes(file.type)) {
          alert(`Unsupported file type: ${file.name}`);
          return;
        }
        uploadFile(file);
      });
    }
    function uploadFile(file) {
      // Simulate upload with progress bar for demo purposes
      progressBarContainer.style.display = 'block';
      progressBar.style.width = '0%';
      let uploaded = 0;
      const total = file.size;
      const speed = total / 50; // simulate upload speed

      function progress() {
        uploaded += speed;
        if (uploaded >= total) {
          progressBar.style.width = '100%';
          setTimeout(() => {
            progressBarContainer.style.display = 'none';
            // Add mock recording to list (normally, here you would send file to backend)
            addMockRecordingFromFile(file);
          }, 500);
        } else {
          const percent = (uploaded / total) * 100;
          progressBar.style.width = percent + '%';
          setTimeout(progress, 50);
        }
      }
      progress();
    }
    function addMockRecordingFromFile(file) {
      // Add a new recording to the mock data with minimal info (no transcript)
      const newRec = {
        id: 'rec' + (recordings.length + 1),
        patient: 'New Patient',
        date: new Date().toISOString().slice(0, 10),
        duration: 'Unknown',
        type: 'live', // Assume live for uploaded file for demo
        transcript: 'Transcript will be generated after processing.',
        summary: null,
        audioUrl: ''
      };
      recordings.push(newRec);
      filterRecordings();
      selectRecording(newRec.id);
      alert(`File "${file.name}" uploaded successfully!`);
    }

    // Event listeners
    uploadDropzone.addEventListener('dragenter', e => { preventDefaults(e); highlight(); });
    uploadDropzone.addEventListener('dragover', e => { preventDefaults(e); highlight(); });
    uploadDropzone.addEventListener('dragleave', e => { preventDefaults(e); unhighlight(); });
    uploadDropzone.addEventListener('drop', e => { preventDefaults(e); unhighlight(); handleDrop(e); });
    uploadDropzone.addEventListener('keypress', e => { if (e.key === 'Enter') fileInput.click(); });

    fileInput.addEventListener('change', e => handleFiles(e.target.files));
    searchInputEl.addEventListener('input', filterRecordings);
    filterTypeEl.addEventListener('change', filterRecordings);

    // Initial render
    filterRecordings();
  })();
</script>
</body>
</html>

